    <!-- The HKY substitution model (Hasegawa, Kishino & Yano, 1985)             -->
    <input spec='beast.base.spec.evolution.substitutionmodel.HKY' id="hky">
        <parameter name='kappa' idref='hky.kappa'/>
        <input id='freqs' name='frequencies' spec='beast.base.spec.evolution.substitutionmodel.Frequencies'>
            <input name='data' idref='alignment'/>
        </input>
    </input>

    <!-- site model                                                              -->
    <input spec='beast.base.spec.evolution.sitemodel.SiteModel' id="siteModel">
        <input name='substModel' idref='hky'/>
    </input>

    <input spec='TreeLikelihood' id="treeLikelihood">
        <input name='data' idref="alignment"/>
        <input name='tree' idref="tree"/>
        <input name='siteModel' idref="siteModel"/>
    </input>


    <input spec='beast.base.spec.evolution.tree.ClusterTree' id='tree' clusterType='upgma'>
        <input name='taxa' idref='alignment'/>
    </input>

    <input spec='RealScalarParam' id="hky.kappa">1.0</input>


    <run spec="MCMC" id="mcmc" chainLength="1000000"> <!--autoOptimize="true"-->
        <state>
            <input name='stateNode' idref='hky.kappa'/>
            <input name='stateNode' idref='tree'/>
        </state>

        <distribution spec="CompoundDistribution" id="posterior">
            <distribution id="coalescent" spec="Coalescent">
                <treeIntervals spec='TreeIntervals' id='TreeIntervals'>
                     <tree idref="tree"/>
                </treeIntervals>
                <populationModel spec="feast.popmodels.CompoundPopulationModel">
                  <populationModel spec="ConstantPopulation" popSize="5.0"/>
                  <populationModel spec="ConstantPopulation" popSize="0.01"/>
                  <populationModel spec="ConstantPopulation" popSize="3.0"/>
                  <changeTimes spec="RealVectorParam" value="0.02 0.05"/>
                </populationModel>
            </distribution>
            <distribution id='likelihood' idref="treeLikelihood"/>
        </distribution>

        <operator id='kappaScaler' spec='beast.base.spec.inference.operator.ScaleOperator' scaleFactor="0.5" weight="1">
            <parameter idref="hky.kappa"/>
        </operator>

        <operator id='treeIntervalScaler' spec='beast.base.spec.evolution.operator.IntervalScaleOperator' scaleFactor="0.5" tree="@tree" weight="3"/>
        <operator id="treeScaler" spec="beast.base.spec.evolution.operator.UpDownOperator" up="@tree" scaleFactor="0.1" weight="4.0"/>
        <operator id="treeRootScaler" spec="kernel.BactrianScaleOperator" scaleFactor="0.5" tree="@tree" rootOnly="true" weight="3"/>
        <operator id="uniformNodeOperator" spec="kernel.BactrianNodeOperator" tree="@tree" weight="30"/>
        <operator id="subtreeSlide" spec="kernel.BactrianSubtreeSlide" size="1.0" tree="@tree" weight="15"/>
        <operator id="exchangeNarrow" spec="Exchange" isNarrow="true" tree="@tree" weight="15"/>
        <operator id="exchangeWidt" spec="Exchange" isNarrow="false" tree="@tree" weight="3"/>
        <operator id="wilsonBalding" spec="WilsonBalding" tree="@tree" weight="3"/>



        <logger logEvery="10000" fileName="$(filebase).log">
   	        <model idref='posterior'/>
            <log idref="coalescent"/>
            <log idref="likelihood"/>
            <log idref="hky.kappa"/>
            <log idref="posterior"/>
            <log id="treeStats" spec="TreeStatLogger" tree="@tree"/>
        </logger>
        <logger logEvery="10000" fileName="$(filebase).trees">
            <log idref="tree"/>
        </logger>
        <logger logEvery="10000">
	        <model idref='posterior'/>
            <log idref="coalescent"/>
            <log idref="likelihood"/>
            <log idref="hky.kappa"/>
            <log idref="posterior"/>
            <log idref="treeStats"/>
        </logger>
    </run>

</beast>
